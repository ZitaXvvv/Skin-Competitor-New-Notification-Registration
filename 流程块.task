dim dic_Competitor, lst_Competitor, hWeb, dictRet, arrayData, dTime, sRet, iRet, src, code, objExcelWorkBook, hWeb_normal, link, spdf_1, istart, arrRet, arrayexcel, reocord_date, upload_time, objRect, objPoint, bRet
/* 所有competitors在美修大数据网站上的搜索名称*/
