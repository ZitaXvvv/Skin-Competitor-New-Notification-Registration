						Delay(5000)
						Mouse.Action(@ui"链接<a>_化妆品Cosmetics1", "left", "click", 10000, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200, "bSetForeground": true, "sCursorPosition": "Center", "iCursorOffsetX": 0, "iCursorOffsetY": 0, "sKeyModifiers": [], "sSimulate": "simulate", "bMoveSmoothly": false})
						/* 检查是否是进口*/
						iRet_1 = InStr(strNum, "进", 1, false)
