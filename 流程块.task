			Mouse.Action(@ui"链接<a>", "left", "click", 10000, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200, "bSetForeground": true, "sCursorPosition": "Center", "iCursorOffsetX": 0, "iCursorOffsetY": 0, "sKeyModifiers": [], "sSimulate": "simulate", "bMoveSmoothly": false})
			Delay(2000)
			arrayData_name = UiElement.DataScrap({"wnd": [{"cls": "Chrome_WidgetWin_1", "title": "*", "app": "msedge"}, {"cls": "Chrome_RenderWidgetHostHWND", "title": "Chrome Legacy Window"}], "html": [{"tag": "TABLE", "css-selector": "body>div>section>section>main>div>div>div>div>div>div>div>div>div>div>div>div>div>div>div>div>div>table"}]}, {"ExtractTable": 1, "Columns": []}, {"objNextLinkElement": {"wnd": [{"cls": "Chrome_WidgetWin_1", "title": "*", "app": "msedge"}, {"cls": "Chrome_RenderWidgetHostHWND", "title": "Chrome Legacy Window"}], "html": [{"tag": "A", "parentid": "scroll-body", "idx": 8}]}, "iMaxNumberOfPage": 3, "iMaxNumberOfResult": -1, "iDelayBetweenMS": 1000, "bContinueOnError": False})

			i = 0
			For Each value In arrayData

				t = Time.CDate(value[9], "yyyy.mm.dd")
