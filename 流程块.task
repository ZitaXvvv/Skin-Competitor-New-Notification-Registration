						spdf = spdf_1 & spdf_2
						Delay(2000)
						istart = InStr(spdf, "1%（w/w）以上成分", 1, false)
						iend = InStr(spdf, "其他微量成分", 1, false)
						spdf = Mid(spdf, istart+11, iend-istart-11)
						TracePrint($PrevResult)

						intgredient = Split(spdf, "、")


						intgredient = Join(intgredient, ",")
						intgredient = "[" & intgredient
						intgredient = intgredient & "]"
						TracePrint($PrevResult)
						WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
						WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
						WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
						WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
						/* 操作excel*/
						arrayexcel = [sTime, name, "", '', strNum, reocord_date, intgredient, link, link_yanggao]
						objExcelWorkBook = Excel.OpenExcel('''C:\Users\xie.x.3\Documents\Olay CI\CI_List_Ada.xlsx''', true, "Excel", "", "")
						Delay(2000)
						Excel.ActiveSheet(objExcelWorkBook, key)
