							Delay(2000)
							/* 获取所有数据*/
							arrayData_Form = UiElement.DataScrap({"wnd": [{"cls": "Chrome_WidgetWin_1", "title": "*", "app": "msedge"}, {"cls": "Chrome_RenderWidgetHostHWND", "title": "Chrome Legacy Window"}], "html": [{"tag": "TABLE", "id": "table1"}]}, {"ExtractTable": 1, "Columns": []}, {"objNextLinkElement": '', "iMaxNumberOfPage": 5, "iMaxNumberOfResult": -1, "iDelayBetweenMS": 1000, "bContinueOnError": False})
							TracePrint(arrayData_Form)
							If iRet_1 <> 0
								name = arrayData_Form[0][2]
								id = arrayData_Form[2][2]
								reocord_date = arrayData_Form[3][2]
								intgredient = arrayData_Form[13][2]
							Else
								name = arrayData_Form[0][2]
								id = arrayData_Form[1][2]
								reocord_date = arrayData_Form[2][2]
								intgredient = arrayData_Form[13][2]
							End If



							intgredient = Replace(intgredient, "\"", "", false)
							/* mini POC link*/
							Mouse.Action(@ui"链接<a>_点击查看", "left", "click", 10000, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200, "bSetForeground": true, "sCursorPosition": "Center", "iCursorOffsetX": 0, "iCursorOffsetY": 0, "sKeyModifiers": [], "sSimulate": "simulate", "bMoveSmoothly": false})
							Delay(1000)
							link_poc = WebBrowser.GetURL(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
							WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
							Delay(1000)
							/* 产品包装 link*/
							Mouse.Action(@ui"链接<a>_预览1", "left", "click", 10000, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200, "bSetForeground": true, "sCursorPosition": "Center", "iCursorOffsetX": 0, "iCursorOffsetY": 0, "sKeyModifiers": [], "sSimulate": "simulate", "bMoveSmoothly": false})

							Delay(3000)

							link = WebBrowser.GetURL(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})

							WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})


							WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})


							WebBrowser.Close(hWeb_normal, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
						End Try



						arrayexcel = [sTime, name, Effect, reocord_date, strNum, "", intgredient, link, "", link_poc]



						/* 操作excel*/


						objExcelWorkBook = Excel.OpenExcel('''C:\Users\xie.x.3\Documents\Olay CI\CI_List_Ada.xlsx''', true, "Excel", "", "")
						Delay(2000)
						Excel.ActiveSheet(objExcelWorkBook, key)
						Excel.InsertLastRow(objExcelWorkBook, key, arrayexcel, true)

						Excel.CloseExcel(objExcelWorkBook, true)

					End If
				End If
				i = i+1
			Next 




		Catch e1
			TracePrint(e1)
		End Try

	Next 



Next 
WebBrowser.Close(hWeb, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})









