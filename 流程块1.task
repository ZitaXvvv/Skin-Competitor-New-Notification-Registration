				Mouse.Wheel(5, "down", [], {"iDelayAfter": 300, "iDelayBefore": 200})
			End Try


		Else
			For i = 0 To 3 step 1
				bool = False
				TracePrint("检测到页面没有发生滚动")
				TracePrint("重新尝试次数："+CStr(i))
				Delay(2000)
				a_1 = UiElement.DataScrap({"wnd": [{"cls": "Chrome_WidgetWin_1", "title": "*", "app": "msedge"}, {"cls": "Chrome_RenderWidgetHostHWND", "title": "Chrome Legacy Window"}], "html": [{"tag": "TABLE", "parentname": "brandUsedIngredient", "aaname": "成分名称"}]}, {"ExtractTable": 1, "Columns": []}, {"objNextLinkElement": '', "iMaxNumberOfPage": 5, "iMaxNumberOfResult": -1, "iDelayBetweenMS": 1000, "bContinueOnError": False})
