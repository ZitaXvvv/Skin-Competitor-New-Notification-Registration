		arrayData = UiElement.DataScrap({"wnd": [{"cls": "Chrome_WidgetWin_1", "title": "*", "app": "msedge"}, {"cls": "Chrome_RenderWidgetHostHWND", "title": "Chrome Legacy Window"}], "html": [{"tag": "TABLE", "parentname": "brandUsedIngredient", "aaname": "成分名称 该品牌下含该成分的商品总数 该品牌下含该成分的商品数量 是否活性 安全风险 主要功效 使用目的 成分安全分 成分美修指*"}]}, {"ExtractTable": 1, "Columns": []}, {"objNextLinkElement": '', "iMaxNumberOfPage": 5, "iMaxNumberOfResult": -1, "iDelayBetweenMS": 1000, "bContinueOnError": False})

		Upper = UBound(arrayData)

		arrayData = splice(arrayData, 2, Upper)



		If s1 <> a_1[1][0]
			s1 = a_1[1][0]
