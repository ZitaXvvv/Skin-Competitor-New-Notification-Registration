		If v <> "成分名称"
			arr_Name = push(arr_Name, v)

		End If
	Next 

	iRet_N = UBound(arr_Name)
	iRet_L = UBound(arrlevel)

	If iRet_N <> iRet_L
		TracePrint("警告：！！！元素数量不符合")
	End If
	objExcelWorkBook = Excel.OpenExcel('''C:\Users\xie.x.3\Documents\Olay CI\CI_List_Ada.xlsx''', true, "Excel", "", "")
	Excel.ActiveSheet(objExcelWorkBook, "Masterdata")
	/* 统计个数*/
	green = 0
	yellow = 0
	red = 0
	low = 0
	middle = 0
	high = 0

	For i = 0 To iRet_N step 1
		Excel.InsertLastRow(objExcelWorkBook, "Masterdata", [sTime, key, arr_Name[i], arrlevel[i], arrrisk[i], arrhuoxing[i]], false)

		sRet = SubStr(arrlevel[i], 1, 1)
		iRet = CInt(sRet)
		If iRet > 0 And iRet < 3
			green = green+1
		ElseIf iRet >= 3 And iRet <= 6
			yellow = yellow+1
		ElseIf iRet > 6
			red = red+1
		End If

		ilow = InStr(arrrisk[i], "致痘风险等级（低）", 1, false)
		imid = InStr(arrrisk[i], "致痘风险等级（中）", 1, false)
		ihigh = InStr(arrrisk[i], "致痘风险等级（高）", 1, false)

		If ilow <> 0
			low = low+1
		End If

		If imid <> 0
			middle = middle+1
		End If

		If ihigh <> 0
			high = high+1
		End If

	Next 

	Excel.ActiveSheet(objExcelWorkBook, "Anlyse")
	Excel.InsertLastRow(objExcelWorkBook, "Anlyse", [sTime, key, green, yellow, red, low, middle, high], false)
	Excel.CloseExcel(objExcelWorkBook, true)

	WebBrowser.Close(hWeb, {"bContinueOnError": false, "iDelayAfter": 300, "iDelayBefore": 200})
Next 
